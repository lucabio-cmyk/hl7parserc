{
  "Bridge": {
    "Folders": {
      "Incoming": "C:\\Hl7Bridge\\incoming",
      "Processing": "C:\\Hl7Bridge\\processing",
      "Sent": "C:\\Hl7Bridge\\sent",
      "Error": "C:\\Hl7Bridge\\error",
      "Logs": "C:\\Hl7Bridge\\logs",
      "Hl7ArchiveEnabled": true,
      "Hl7Archive": "C:\\Hl7Bridge\\hl7_archive"
    },
    "Lis": {
      "Host": "10.10.10.25",
      "Port": 2575,
      "RetryCount": 3,
      "RetryIntervalMs": 3000,
      "AckTimeoutMs": 10000
    },
    "Hl7": {
      "Version": "2.5.1",
      "SendingApplication": "PCR_INSTRUMENT_BRIDGE",
      "SendingFacility": "LAB_A",
      "ReceivingApplication": "CENTRAL_LIS",
      "ReceivingFacility": "MAIN_HOSPITAL",
      "ProcessingId": "P",
      "PlaceholderPatientIdPrefix": "SAMPLE",
      "TargetCodeMap": {
        "Klebsiella pneumoniae": {
          "Code": "KPNEU",
          "CodingSystem": "99LAB",
          "ValueTypeForCopies": "NM",
          "Units": "copies/uL"
        },
        "Escherichia coli": {
          "Code": "ECOLI",
          "CodingSystem": "99LAB",
          "ValueTypeForCopies": "NM",
          "Units": "copies/uL"
        },
        "Pseudomonas aeruginosa": {
          "Code": "PAERU",
          "CodingSystem": "99LAB",
          "ValueTypeForCopies": "NM",
          "Units": "copies/uL"
        },
        "Internal Control": {
          "Code": "INTCTRL",
          "CodingSystem": "99LAB",
          "ValueTypeForCopies": "NM",
          "Units": "copies/uL"
        }
      }
    },
    "Processing": {
      "PollIntervalMs": 2000,
      "StableFileWaitMs": 5000,
      "StableFileProbeIntervalMs": 1000,
      "MaxFilesPerCycle": 5,
      "DuplicateRetentionDays": 30
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ]
  }
}
